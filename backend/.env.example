GEMINI_API_KEY=replace-with-your-google-ai-studio-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# LangSmith observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=site-extension-rag
LANGSMITH_TRACING=false

# Comma-separated origins or JSON array; default allows all local extension origins
CORS_ALLOW_ORIGINS=*

# Vector store backend: "local" (FAISS) or "qdrant"
VECTOR_STORE_BACKEND=local
